# ─────────────────────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────────────────────
# Meta Conversions API (CAPI) — UN SOLO PIXEL para todas las marcas
# ─────────────────────────────────────────────────────────────
# Pixel ID (también llamado "Dataset ID") del Pixel/Conjunto de datos en
# Events Manager. Es el mismo para todas las marcas.
META_PIXEL_ID=

# Token de acceso de la Conversions API (System User token con permiso
# ads_management sobre el Pixel). Se genera en Events Manager → Configuración
# → Conversions API → Generar token de acceso.
META_ACCESS_TOKEN=

# Versión del Graph API a usar (ej. v21.0).
META_GRAPH_API_VERSION=v21.0

# (Opcional) Código de evento de prueba para validar en la pestaña
# "Probar eventos" de Events Manager. Dejar vacío en producción.
META_TEST_EVENT_CODE=

# Moneda para eventos Purchase (Meta la exige). Ecuador usa USD.
META_DEFAULT_CURRENCY=USD

# Valor por defecto para eventos Purchase cuando el payload no trae monto.
# Configura un ticket promedio si quieres optimización por valor.
META_DEFAULT_PURCHASE_VALUE=0

# Nombre de la fuente CRM para Conversion Leads (custom_data.lead_event_source).
# Solo se usa en eventos que traen el leadgen_id de Meta.
META_LEAD_EVENT_SOURCE=ASSA CRM

# País por defecto (ISO 2 letras) para Advanced Matching. ASSA opera en Ecuador.
# Dejar vacío para no enviarlo.
META_DEFAULT_COUNTRY=ec

# ─────────────────────────────────────────────────────────────
# GatherLeads (CarConnect)
# ─────────────────────────────────────────────────────────────
# Secret Key acordada con GatherLeads al crear el webhook. El header y el
# algoritmo exactos deben confirmarse con su equipo (ver README).
GATHERLEADS_SECRET=

# Nombre del header donde GatherLeads envía la firma (a confirmar con ellos).
# Por defecto: x-gatherleads-signature
GATHERLEADS_SIGNATURE_HEADER=x-gatherleads-signature

# Si es "true" se rechazan los eventos cuya firma no se pueda verificar.
# Mientras GatherLeads no confirme el mecanismo, dejar en "false".
GATHERLEADS_VERIFY_SIGNATURE=false

# (Opcional) Nombre exacto del campo del payload con el Meta leadgen_id.
# Si se deja vacío, se autodetecta un valor de 15-17 dígitos en el deal.
GATHERLEADS_LEAD_ID_FIELD=

# ─────────────────────────────────────────────────────────────
# Comportamiento
# ─────────────────────────────────────────────────────────────
# Si es "true", los eventos cuya etapa no esté mapeada a un evento de Meta
# se ignoran silencientemente (responden 200 sin enviar a Meta).
SKIP_UNMAPPED_STAGES=true

# Nivel de log: debug | info | warn | error
LOG_LEVEL=info
